    "compile": "node compile-engines.js && tsc",
    "build": "tsc",
    "ready-up": "npm run remove-results ; npm run remove-cache ; npm run compile && npm run build",
    "remove-results": "cd results && cp -r ./benchmarkConfigs/ ./results-old/ &&  cp -r ./resultsData/ ./results-old/ && rm -r ./benchmarkConfigs &&  rm -r ./resultsData && cd ..",
